#!/usr/bin/env bash
set -euo pipefail

# dot-sync: sync dotfiles between $HOME and this repo, with confirm-before-overwrite.
# Tracks:
#   ~/.vimrc
#   ~/.bashrc
#   ~/.gitconfig
#   ~/.git-completion.bash
#   ~/.local/bin/{git-ai-commit,git-clean-local-branches,git-clean-rebase,convert-heics-to-jpgs,organize-files}
#   ~/.claude/skills/    (directory)
#   ~/.claude/commands/  (directory)

# -------------------------------------------------------------------
# Repo dir = directory containing this script
# -------------------------------------------------------------------
if [[ -z "${DOTSYNC_REPO:-}" ]]; then
  DOTSYNC_REPO="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  export DOTSYNC_REPO
fi
HOME_DIR="$HOME"
REPO_DIR="$DOTSYNC_REPO"

FILES=(
  ".vimrc"
  ".bashrc"
  ".gitconfig"
  ".git-completion.bash"
  ".inputrc"
  ".sdirs"
  ".local/bin/git-ai-commit"
  ".local/bin/git-clean-local-branches"
  ".local/bin/git-clean-rebase"
  ".local/bin/git-peek-format"
  ".local/bin/convert-heics-to-jpgs"
  ".local/bin/organize-files"
  "Library/Application Support/Amethyst/Layouts/centered-primary-columns.js"
  "Library/Application Support/Amethyst/Layouts/centered-twin-columns.js"
  "Library/Application Support/Amethyst/Layouts/centered-resizable-pane-with-cols.js"
  "Library/Application Support/Amethyst/Layouts/uniform-columns.js"
  ".config/nvim/lua/config/aerial.lua"
  ".config/nvim/lua/config/autocmds.lua"
  ".config/nvim/lua/config/keymaps.lua"
  ".config/nvim/lua/config/lazy.lua"
  ".config/nvim/lua/config/options.lua"
  ".config/nvim/lua/plugins/example.lua"
  ".config/nvim/lua/plugins/lualine.lua"
  ".config/nvim/lua/plugins/telescope.lua"
)

# Directory entries — entire directories synced recursively.
# Format: "local_rel_path" or "local_rel_path => repo_rel_path"
# Default repo path equals the local path (unlike FILES which uses basename).
DIRS=(
  ".claude/skills"
  ".claude/commands"
)

usage() {
  cat <<EOF
dot-sync — sync a handful of dotfiles between \$HOME and this git repo.

Usage:
  dot-sync [options] status|diff
  dot-sync [options] pull   Copy repo -> local (confirm before overwrite; backup if changed)
  dot-sync [options] push   Copy local -> repo (confirm before overwrite; backup if changed), then git-ai-commit + git push
  dot-sync [options] sync   Walk each diff hunk and choose repo -> local, local -> repo, or ignore

Options:
  -y, --yes              Skip overwrite confirmations; for sync, auto-select Repo -> Local
  -h, --help             Show this help
EOF
}

# -------------------------------------------------------------------
# Helpers
# -------------------------------------------------------------------
log() { printf "[dot-sync] %s\n" "$*"; }
warn() { printf "[dot-sync:WARN] %s\n" "$*" >&2; }

ASSUME_YES=false
have_colordiff=false
command -v colordiff >/dev/null 2>&1 && have_colordiff=true

show_diff() {
  # $1 = old (dest), $2 = new (src)
  if [[ -e "$1" ]]; then
    if $have_colordiff; then
      colordiff -u "$1" "$2" || true
    else
      diff -u "$1" "$2" || true
    fi
  else
    echo "--- $1 (missing)"
    echo "+++ $2"
    if $have_colordiff; then
      colordiff -u /dev/null "$2" || true
    else
      diff -u /dev/null "$2" || true
    fi
  fi
}

backup_if_changed() {
  # $1 = path to back up
  local target="$1"
  if [[ -e "$target" ]]; then
    # Format: bak.YYYY-MMDD-HHMMSS under $REPO_DIR/.bak/<filename>/
    local ts
    ts="$(date +%Y-%m%d-%H%M%S)"
    local bak_root bak_name bak_dir bak_file
    bak_root="$REPO_DIR/.bak"
    bak_name="$(basename "$target")"
    bak_dir="$bak_root/$bak_name"
    bak_file="$bak_dir/bak.$ts"
    mkdir -p "$bak_dir"
    cp -p "$target" "$bak_file"
    log "Backed up: $target -> $bak_file"
  fi
}

ensure_parent() { mkdir -p "$(dirname "$1")"; }

reload_bashrc() {
  local bashrc="$HOME_DIR/.bashrc"
  if [[ -f "$bashrc" ]]; then
    # Best-effort reload for this process; parent interactive shell still
    # requires an explicit `source ~/.bashrc` to import env/function changes.
    # shellcheck disable=SC1090
    if (set +u; source "$bashrc"); then
      log "Reloaded $bashrc"
    else
      warn "Failed to source $bashrc"
    fi
  else
    warn "$bashrc not found; skipping source."
  fi
}

# Parse entry that may be either a simple relative path or a mapping in the
# form: "local_path => repo_path". Prints "local|repo".
split_entry() {
  local entry="$1"
  local local_rel repo_rel
  if [[ "$entry" == *"=>"* ]]; then
    local_rel="${entry%%=>*}"
    repo_rel="${entry#*=>}"
  else
    local_rel="$entry"
    # Implicit mapping: always map repo path to the basename of the local path
    repo_rel="${local_rel##*/}"
  fi
  # trim leading/trailing whitespace on both sides
  local_rel="${local_rel#${local_rel%%[![:space:]]*}}"
  local_rel="${local_rel%${local_rel##*[![:space:]]}}"
  repo_rel="${repo_rel#${repo_rel%%[![:space:]]*}}"
  repo_rel="${repo_rel%${repo_rel##*[![:space:]]}}"
  printf '%s|%s' "$local_rel" "$repo_rel"
}

# Like split_entry but defaults repo path = local path (not basename) — for directories.
split_dir_entry() {
  local entry="$1"
  local local_rel repo_rel
  if [[ "$entry" == *"=>"* ]]; then
    local_rel="${entry%%=>*}"
    repo_rel="${entry#*=>}"
  else
    local_rel="$entry"
    repo_rel="$entry"
  fi
  local_rel="${local_rel#${local_rel%%[![:space:]]*}}"
  local_rel="${local_rel%${local_rel##*[![:space:]]}}"
  repo_rel="${repo_rel#${repo_rel%%[![:space:]]*}}"
  repo_rel="${repo_rel%${repo_rel##*[![:space:]]}}"
  printf '%s|%s' "$local_rel" "$repo_rel"
}

confirm_overwrite() {
  # $1 = dest path, $2 = src path, $3 = label (for display)
  local dest="$1" src="$2" label="$3"
  if [[ -e "$dest" ]] && ! cmp -s "$dest" "$src"; then
    echo "=== DIFF for $label ==="
    show_diff "$dest" "$src"
    if $ASSUME_YES; then
      log "Auto-confirm enabled; overwriting: $label"
      return 0
    fi
    read -r -p "Overwrite $dest with $src ? [y/N] " ans
    case "${ans:-}" in
    y | Y | yes | YES) return 0 ;;
    *)
      echo "Skipped: $label"
      return 1
      ;;
    esac
  fi
  # If dest doesn't exist or files are identical, no prompt needed
  return 0
}

copy_with_confirm() {
  # $1 = src, $2 = dest, $3 = label (e.g., .bashrc), $4 = post_copy_chmod (optional mode or empty)
  local src="$1" dest="$2" label="$3" mode="${4:-}"
  ensure_parent "$dest"

  # If identical, do nothing.
  if [[ -e "$dest" ]] && cmp -s "$dest" "$src"; then
    log "No change: $label"
    return 0
  fi

  # Confirm if we're about to overwrite an existing, different file
  if ! confirm_overwrite "$dest" "$src" "$label"; then
    return 0
  fi

  # Make backup (only if dest exists and differs or exists at all)
  [[ -e "$dest" ]] && backup_if_changed "$dest"

  # Copy and optionally chmod
  cp -fp "$src" "$dest"
  [[ -n "$mode" ]] && chmod "$mode" "$dest" || true
  log "Copied: $label"
}

copy_repo_to_local() {
  local entry="$1"
  local pair
  pair="$(split_entry "$entry")"
  local local_rel="${pair%%|*}" repo_rel="${pair##*|}"
  local src="$REPO_DIR/$repo_rel" dst="$HOME_DIR/$local_rel"
  [[ -e "$src" ]] || {
    log "Repo missing $repo_rel (skip)"
    return
  }
  # Executables in .local/bin get +x when copying to local
  local mode=""
  [[ "$local_rel" == .local/bin/* ]] && mode="0755"
  copy_with_confirm "$src" "$dst" "Repo → Local: $local_rel" "$mode"
}

copy_local_to_repo() {
  local entry="$1"
  local pair
  pair="$(split_entry "$entry")"
  local local_rel="${pair%%|*}" repo_rel="${pair##*|}"
  local src="$HOME_DIR/$local_rel" dst="$REPO_DIR/$repo_rel"
  [[ -e "$src" ]] || {
    log "Local missing $local_rel (skip)"
    return
  }
  # Preserve exec bit when syncing into repo for local executables
  local mode=""
  if [[ "$local_rel" == .local/bin/* && -x "$src" ]]; then mode="0755"; fi
  copy_with_confirm "$src" "$dst" "Local → Repo: $repo_rel" "$mode"
}

copy_dir_repo_to_local() {
  local entry="$1"
  local pair
  pair="$(split_dir_entry "$entry")"
  local local_rel="${pair%%|*}" repo_rel="${pair##*|}"
  local repo_dir="$REPO_DIR/$repo_rel" local_dir="$HOME_DIR/$local_rel"
  [[ -d "$repo_dir" ]] || { log "Repo dir missing: $repo_rel (skip)"; return; }
  while IFS= read -r -d '' repo_file; do
    local rel="${repo_file#${repo_dir}/}"
    copy_with_confirm "$repo_file" "$local_dir/$rel" "Repo → Local: $local_rel/$rel" ""
  done < <(find "$repo_dir" -type f -print0)
}

copy_dir_local_to_repo() {
  local entry="$1"
  local pair
  pair="$(split_dir_entry "$entry")"
  local local_rel="${pair%%|*}" repo_rel="${pair##*|}"
  local local_dir="$HOME_DIR/$local_rel" repo_dir="$REPO_DIR/$repo_rel"
  [[ -d "$local_dir" ]] || { log "Local dir missing: $local_rel (skip)"; return; }
  while IFS= read -r -d '' local_file; do
    local rel="${local_file#${local_dir}/}"
    copy_with_confirm "$local_file" "$repo_dir/$rel" "Local → Repo: $repo_rel/$rel" ""
  done < <(find "$local_dir" -type f -print0)
}

status_dir() {
  local entry="$1"
  local pair
  pair="$(split_dir_entry "$entry")"
  local local_rel="${pair%%|*}" repo_rel="${pair##*|}"
  local local_dir="$HOME_DIR/$local_rel" repo_dir="$REPO_DIR/$repo_rel"
  local ret=0
  if [[ -d "$local_dir" ]]; then
    while IFS= read -r -d '' local_file; do
      local rel="${local_file#${local_dir}/}"
      local repo_file="$repo_dir/$rel"
      if [[ ! -e "$repo_file" ]]; then
        echo "only-in-local: $local_rel/$rel"
        ret=1
      elif ! cmp -s "$local_file" "$repo_file"; then
        echo "diff -- $local_rel/$rel ↔ $repo_rel/$rel"
        diff -u "$repo_file" "$local_file" || true
        ret=1
      fi
    done < <(find "$local_dir" -type f -print0)
  fi
  if [[ -d "$repo_dir" ]]; then
    while IFS= read -r -d '' repo_file; do
      local rel="${repo_file#${repo_dir}/}"
      [[ -e "$local_dir/$rel" ]] || { echo "only-in-repo:  $repo_rel/$rel"; ret=1; }
    done < <(find "$repo_dir" -type f -print0)
  fi
  [[ "$ret" -eq 0 ]] && log "No change: $local_rel/"
  return $ret
}

sync_dir() {
  local entry="$1"
  local pair
  pair="$(split_dir_entry "$entry")"
  local local_rel="${pair%%|*}" repo_rel="${pair##*|}"
  local local_dir="$HOME_DIR/$local_rel" repo_dir="$REPO_DIR/$repo_rel"
  local -a all_rels=()
  if [[ -d "$local_dir" ]]; then
    while IFS= read -r -d '' f; do
      all_rels+=("${f#${local_dir}/}")
    done < <(find "$local_dir" -type f -print0)
  fi
  if [[ -d "$repo_dir" ]]; then
    while IFS= read -r -d '' f; do
      local rel="${f#${repo_dir}/}"
      local found=false
      for existing in "${all_rels[@]+"${all_rels[@]}"}"; do
        [[ "$existing" == "$rel" ]] && found=true && break
      done
      $found || all_rels+=("$rel")
    done < <(find "$repo_dir" -type f -print0)
  fi
  for rel in "${all_rels[@]+"${all_rels[@]}"}"; do
    local l="$local_dir/$rel" r="$repo_dir/$rel"
    if [[ -e "$l" && -e "$r" ]]; then
      if cmp -s "$l" "$r"; then
        log "No change: $local_rel/$rel"
      else
        sync_existing_pair_by_hunk "$local_rel/$rel" "$repo_rel/$rel" "$l" "$r"
      fi
    else
      sync_missing_pair "$local_rel/$rel" "$repo_rel/$rel" "$l" "$r"
    fi
  done
}

show_patch_file() {
  local patch_file="$1"
  if $have_colordiff; then
    colordiff <"$patch_file" || true
  else
    cat "$patch_file"
  fi
}

show_reverse_patch_file() {
  # Display a patch with --- and +++ headers and +/- signs swapped
  local patch_file="$1"
  local reversed
  reversed="$(awk '
    /^--- / { sub(/^--- /, "+++ "); print; next }
    /^\+\+\+ / { sub(/^\+\+\+ /, "--- "); print; next }
    /^@@ / { print; next }
    /^\+/ { sub(/^\+/, "-"); print; next }
    /^-/ { sub(/^-/, "+"); print; next }
    { print }
  ' "$patch_file")"
  if $have_colordiff; then
    printf '%s\n' "$reversed" | colordiff || true
  else
    printf '%s\n' "$reversed"
  fi
}

sync_choice_prompt() {
  # Prints one of: repo_to_local | local_to_repo | ignore
  # $1 = context label
  local label="$1"
  local ans
  if $ASSUME_YES; then
    printf "[dot-sync] Auto-confirm enabled; selecting repo -> local for %s\n" "$label" >&2
    echo "repo_to_local"
    return 0
  fi
  while true; do
    echo "Choose sync direction for $label:" >&2
    echo "  1) Repo -> Local" >&2
    echo "  2) Local -> Repo" >&2
    echo "  3) Ignore" >&2
    read -r -p "Enter 1, 2, or 3 [3]: " ans
    case "${ans:-3}" in
    1) echo "repo_to_local"; return 0 ;;
    2) echo "local_to_repo"; return 0 ;;
    3) echo "ignore"; return 0 ;;
    *) echo "Invalid choice: ${ans}. Please enter 1, 2, or 3." >&2 ;;
    esac
  done
}

sync_existing_pair_by_hunk() {
  # $1 = local_rel, $2 = repo_rel, $3 = local_abs, $4 = repo_abs
  local local_rel="$1" repo_rel="$2" local_abs="$3" repo_abs="$4"
  local tmp_dir
  tmp_dir="$(mktemp -d)"
  local full_diff="$tmp_dir/full.diff"

  local diff_ec=0
  diff -u "$local_abs" "$repo_abs" >"$full_diff" || diff_ec=$?
  if [[ "$diff_ec" -gt 1 ]]; then
    warn "Failed to diff $local_rel ↔ $repo_rel (exit $diff_ec); skipping."
    rm -rf "$tmp_dir"
    return
  fi

  if ! grep -q '^@@ ' "$full_diff"; then
    # Most likely a binary file diff or format we cannot hunk-split.
    echo "=== [1] Repo -> Local: local file will change ===" >&2
    show_diff "$local_abs" "$repo_abs"
    echo "=== [2] Local -> Repo: repo file will change ===" >&2
    show_diff "$repo_abs" "$local_abs"
    local action
    action="$(sync_choice_prompt "$local_rel ↔ $repo_rel (file-level)")"
    case "$action" in
    repo_to_local)
      backup_if_changed "$local_abs"
      cp -fp "$repo_abs" "$local_abs"
      [[ "$local_rel" == .local/bin/* ]] && chmod 0755 "$local_abs" || true
      log "Synced file: Repo -> Local ($local_rel)"
      ;;
    local_to_repo)
      backup_if_changed "$repo_abs"
      cp -fp "$local_abs" "$repo_abs"
      if [[ "$local_rel" == .local/bin/* && -x "$local_abs" ]]; then chmod 0755 "$repo_abs"; fi
      log "Synced file: Local -> Repo ($repo_rel)"
      ;;
    ignore) log "Ignored file: $local_rel ↔ $repo_rel" ;;
    esac
    rm -rf "$tmp_dir"
    return
  fi

  awk -v out="$tmp_dir" '
    !seen_hunk && /^--- / { old=$0; next }
    !seen_hunk && /^\+\+\+ / { new=$0; next }
    /^@@ / {
      seen_hunk=1
      n++
      f=sprintf("%s/hunk_%04d.patch", out, n)
      print old > f
      print new >> f
      print $0 >> f
      next
    }
    n>0 { print >> f }
    END { print n > sprintf("%s/hunk_count", out) }
  ' "$full_diff"

  local hunk_count=0
  if [[ -f "$tmp_dir/hunk_count" ]]; then
    hunk_count="$(cat "$tmp_dir/hunk_count")"
  fi
  if [[ "$hunk_count" -le 0 ]]; then
    warn "No hunks detected for $local_rel ↔ $repo_rel; skipping."
    rm -rf "$tmp_dir"
    return
  fi

  local local_backed_up=false
  local repo_backed_up=false
  local i hunk_file action
  for ((i = 1; i <= hunk_count; i++)); do
    hunk_file="$(printf '%s/hunk_%04d.patch' "$tmp_dir" "$i")"
    echo "=== HUNK $i/$hunk_count for $local_rel ↔ $repo_rel ===" >&2
    echo "--- [1] Repo -> Local: local file will change ---" >&2
    show_patch_file "$hunk_file"
    echo "--- [2] Local -> Repo: repo file will change ---" >&2
    show_reverse_patch_file "$hunk_file"
    action="$(sync_choice_prompt "$local_rel hunk $i/$hunk_count")"
    case "$action" in
    repo_to_local)
      if ! $local_backed_up; then
        backup_if_changed "$local_abs"
        local_backed_up=true
      fi
      if patch --quiet --forward "$local_abs" <"$hunk_file"; then
        [[ "$local_rel" == .local/bin/* ]] && chmod 0755 "$local_abs" || true
        log "Applied hunk $i/$hunk_count: Repo -> Local ($local_rel)"
      else
        warn "Failed applying hunk $i/$hunk_count Repo -> Local for $local_rel"
      fi
      ;;
    local_to_repo)
      if ! $repo_backed_up; then
        backup_if_changed "$repo_abs"
        repo_backed_up=true
      fi
      if patch --quiet --forward -R "$repo_abs" <"$hunk_file"; then
        if [[ "$local_rel" == .local/bin/* && -x "$local_abs" ]]; then chmod 0755 "$repo_abs"; fi
        log "Applied hunk $i/$hunk_count: Local -> Repo ($repo_rel)"
      else
        warn "Failed applying hunk $i/$hunk_count Local -> Repo for $repo_rel"
      fi
      ;;
    ignore)
      log "Ignored hunk $i/$hunk_count for $local_rel ↔ $repo_rel"
      ;;
    esac
  done

  rm -rf "$tmp_dir"
}

sync_missing_pair() {
  # $1 = local_rel, $2 = repo_rel, $3 = local_abs, $4 = repo_abs
  local local_rel="$1" repo_rel="$2" local_abs="$3" repo_abs="$4"
  local action
  if [[ -e "$repo_abs" && ! -e "$local_abs" ]]; then
    action="$(sync_choice_prompt "$local_rel missing locally (repo has file)")"
    case "$action" in
    repo_to_local)
      ensure_parent "$local_abs"
      cp -fp "$repo_abs" "$local_abs"
      [[ "$local_rel" == .local/bin/* ]] && chmod 0755 "$local_abs" || true
      log "Created local from repo: $local_rel"
      ;;
    local_to_repo)
      backup_if_changed "$repo_abs"
      rm -f "$repo_abs"
      log "Removed repo file to match missing local: $repo_rel"
      ;;
    ignore) log "Ignored missing-local pair: $local_rel ↔ $repo_rel" ;;
    esac
  elif [[ -e "$local_abs" && ! -e "$repo_abs" ]]; then
    action="$(sync_choice_prompt "$repo_rel missing in repo (local has file)")"
    case "$action" in
    repo_to_local)
      backup_if_changed "$local_abs"
      rm -f "$local_abs"
      log "Removed local file to match missing repo: $local_rel"
      ;;
    local_to_repo)
      ensure_parent "$repo_abs"
      cp -fp "$local_abs" "$repo_abs"
      if [[ "$local_rel" == .local/bin/* && -x "$local_abs" ]]; then chmod 0755 "$repo_abs"; fi
      log "Created repo file from local: $repo_rel"
      ;;
    ignore) log "Ignored missing-repo pair: $local_rel ↔ $repo_rel" ;;
    esac
  else
    log "Missing both (skip): $local_rel | $repo_rel"
  fi
}

do_sync() {
  local entry pair local_rel repo_rel l r
  for entry in "${FILES[@]}"; do
    pair="$(split_entry "$entry")"
    local_rel="${pair%%|*}"
    repo_rel="${pair##*|}"
    l="$HOME_DIR/$local_rel"
    r="$REPO_DIR/$repo_rel"

    if [[ -e "$l" && -e "$r" ]]; then
      if cmp -s "$l" "$r"; then
        log "No change: $local_rel"
      else
        sync_existing_pair_by_hunk "$local_rel" "$repo_rel" "$l" "$r"
      fi
    else
      sync_missing_pair "$local_rel" "$repo_rel" "$l" "$r"
    fi
  done
  for entry in "${DIRS[@]}"; do sync_dir "$entry"; done
  reload_bashrc
}

do_status() {
  local ret=0
  for entry in "${FILES[@]}"; do
    local pair
    pair="$(split_entry "$entry")"
    local local_rel="${pair%%|*}" repo_rel="${pair##*|}"
    local l="$HOME_DIR/$local_rel" r="$REPO_DIR/$repo_rel"
    if [[ -e "$l" && -e "$r" ]]; then
      if ! cmp -s "$l" "$r"; then
        echo "diff -- $local_rel ↔ $repo_rel"
        diff -u "$r" "$l" || true
        ret=1
      fi
    elif [[ -e "$l" && ! -e "$r" ]]; then
      echo "only-in-local: $local_rel"
      ret=1
    elif [[ ! -e "$l" && -e "$r" ]]; then
      echo "only-in-repo:  $repo_rel"
      ret=1
    else
      echo "missing-both:  $local_rel | $repo_rel"
    fi
  done
  for entry in "${DIRS[@]}"; do status_dir "$entry" || ret=1; done
  return $ret
}

do_pull() {
  # Ensure bashmarks.sh is installed
  local bashmarks="$HOME_DIR/.local/bin/bashmarks.sh"
  if [[ ! -f "$bashmarks" ]]; then
    log "bashmarks.sh not found; downloading..."
    mkdir -p "$(dirname "$bashmarks")"
    if curl -fsSL https://raw.githubusercontent.com/huyng/bashmarks/master/bashmarks.sh -o "$bashmarks"; then
      log "Downloaded bashmarks.sh"
    else
      warn "Failed to download bashmarks.sh"
    fi
  fi

  for rel in "${FILES[@]}"; do copy_repo_to_local "$rel"; done
  for entry in "${DIRS[@]}"; do copy_dir_repo_to_local "$entry"; done
  reload_bashrc
}

do_push() {
  for rel in "${FILES[@]}"; do copy_local_to_repo "$rel"; done
  for entry in "${DIRS[@]}"; do copy_dir_local_to_repo "$entry"; done
  log "Push copy complete."

  # Auto-commit via repo's git-ai-commit, then push to remote
  if command -v git >/dev/null 2>&1 && [[ -d "$REPO_DIR/.git" ]]; then
    (
      cd "$REPO_DIR"
      # If nothing changed, bail early (avoid empty commit)
      if git diff --quiet && git diff --cached --quiet; then
        log "No repo changes to commit."
      else
        git add -A
        if [[ -x "$REPO_DIR/git-ai-commit" ]]; then
          "$REPO_DIR/git-ai-commit"
          log "Committed using git-ai-commit."
        else
          warn "git-ai-commit not found or not executable; skipping commit."
        fi
      fi

      # Push if a remote exists
      if git remote get-url origin >/dev/null 2>&1; then
        if git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1; then
          git push
        else
          cur_branch="$(git rev-parse --abbrev-ref HEAD)"
          git push -u origin "$cur_branch"
        fi
        log "Pushed to remote."
      else
        warn "No 'origin' remote configured; skipped git push."
      fi
    )
  else
    warn "Not a git repo or git unavailable; skipped commit/push."
  fi
}

# -------------------------------------------------------------------
# Commands
# -------------------------------------------------------------------
cmd=""
for arg in "$@"; do
  case "$arg" in
  -y | --yes) ASSUME_YES=true ;;
  -h | --help)
    usage
    exit 0
    ;;
  status | diff | pull | push | sync)
    if [[ -n "$cmd" ]]; then
      echo "Multiple commands provided: '$cmd' and '$arg'" >&2
      usage
      exit 1
    fi
    cmd="$arg"
    ;;
  "")
    ;;
  *)
    echo "Unknown argument: $arg" >&2
    usage
    exit 1
    ;;
  esac
done

case "${cmd:-}" in
status | diff) do_status ;;
pull) do_pull ;;
push) do_push ;;
sync) do_sync ;;
"") usage ;;
esac

# -------------------------------------------------------------------
# PATH update so you can call dot-sync anywhere
# -------------------------------------------------------------------
pathappend() { case ":$PATH:" in *":$1:"*) ;; *) PATH="$PATH:$1" ;; esac }
pathappend "$REPO_DIR"
