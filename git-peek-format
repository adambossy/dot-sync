#!/usr/bin/env bash
awk '
function flush(    i) {
    for (i = 1; i <= (n < 5 ? n : 5); i++)
        print "  " i ". " f[i]
    if (n > 5)
        print "  ... " (n - 5) " more file" (n - 5 == 1 ? "" : "s")
    n = 0
}
/\033/ { flush(); print }
!/\033/ && NF { f[++n] = $0 }
!NF { flush(); print "" }
END { flush() }
'
